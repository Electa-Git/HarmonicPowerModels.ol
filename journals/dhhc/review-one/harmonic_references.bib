	author = {Ćuk, Vladimir and Cobben, Joseph F.G. and Kling, Wil L. and Ribeiro, Paulo F.},
	month = dec,
	year = {2013},
	pages = {1391--1400},
}

@inproceedings{xiao_harmonic_2012,
